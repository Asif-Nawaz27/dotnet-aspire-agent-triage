<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <UserSecretsId>incident-triage-agent-service</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <!-- Semantic Kernel core + OpenAI connector (Groq uses OpenAI-compatible API) -->
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.33.0" />
    <PackageReference Include="Microsoft.SemanticKernel.Connectors.OpenAI" Version="1.33.0" />
    <!-- MCP C# SDK — client-side for importing tools into SK -->
    <PackageReference Include="ModelContextProtocol" Version="1.3.0" />
    <!-- Aspire service discovery -->
    <PackageReference Include="Microsoft.Extensions.ServiceDiscovery" Version="9.7.0" />
    <PackageReference Include="ModelContextProtocol.Core" Version="1.3.0" />
    <!-- Serilog — file + console structured logging -->
    <PackageReference Include="Serilog.Extensions.Hosting" Version="8.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DotNetAspireTriageAgent.ServiceDefaults\DotNetAspireTriageAgent.ServiceDefaults.csproj" />
  </ItemGroup>

</Project>
